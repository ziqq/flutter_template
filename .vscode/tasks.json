    {
      "label": "dart:pubspec_generator:generate",
      "detail": "Generate pubspec file",
      "icon": {
        "color": "terminal.ansiGreen",
        "id": "file-text"
      },
      "type": "shell",
      "command": [
        "fvm dart pub global activate pubspec_generator",
        "&& fvm dart pub global run pubspec_generator:generate -o lib/src/common/constant/pubspec.yaml.g.dart",
      ],
      "dependsOn": [
        "flutter:pub:get"
      ],
      "options": {},
      "problemMatcher": []
    },
    {
      "label": "dart:sheety_localization:generate",
      "detail": "Generate localization files from Google Sheets",
      "icon": {
        "color": "terminal.ansiGreen",
        "id": "file-code"
      },
      "type": "shell",
      "command": [
        "fvm dart pub global activate sheety_localization",
        "&& fvm dart pub global run sheety_localization:generate --credentials=credentials.json",
        "--sheet=...",
        "--lib=lib",
        "--arb=src/l10n",
        "--gen=src/generated",
        "--prefix=app",
        "--author='Author Name <example@gmail.com>'",
        "--comment='Generated from Google Sheets'",
        "--context='From Google Sheets'",
        "--format"
      ],
      "options": {
        "cwd": "${workspaceFolder}/packages/localization"
      },
      "problemMatcher": []
    },
    {
      "label": "dart:format",
      "detail": "Format all files in the project",
      "icon": {
        "color": "terminal.ansiGreen",
        "id": "lightbulb-autofix"
      },
      "type": "shell",
      "command": [
        "find lib test ",
        "-path '*/generated/*' -prune -o ",
        "-type f -name '*.dart' ",
        "! -name '*.*.dart' ",
        "! -name 'messages_.*.dart' ",
        "! -name 'l10n.dart' ",
        "-print0 | xargs -0 dart format --set-exit-if-changed --line-length 120"
      ],
      "dependsOn": [],
      "args": [],
      "group": {
        "kind": "none",
        "isDefault": true
      },
      "problemMatcher": [],
      "options": {
