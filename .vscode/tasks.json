      "icon": {
        "color": "terminal.ansiGreen",
        "id": "cloud-download"
      },
      "dependsOn": [],
      "type": "shell",
      "command": [
        "rm -rf build && rm -rf ios/Podfile.lock && fvm flutter clean && fvm flutter pub get && cd ios && pod install --repo-update"
