      "label": "flutter:test:feature",
      "detail": "Run tests for a specific feature",
      "icon": {
        "color": "terminal.ansiGreen",
        "id": "bug"
      },
      "dependsOn": ["flutter:pub:get"],
      "type": "shell",
      "command": [
        "fvm flutter test --color --coverage --concurrency=50 --platform=tester --reporter=expanded --timeout=30s --tags=\"${input:featureName}\" test/unit_test.dart test/widget_test.dart"
      ],
      "args": [],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
