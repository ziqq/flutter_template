{
  "dart.flutterSdkPath": ".fvm/versions/stable",
  "dart.lineLength": 120,
  "dart.doNotFormat": [
    "**/generated/**",
    "**.gen.dart",
    "**.g.dart",
    "**.gql.dart",
    "**.freezed.dart",
    "**.config.dart",
    "**.mocks.dart",
    "**.pb.dart",
    "**.pbenum.dart",
    "**.pbjson.dart",
    "**.endpoint.dart",
    "**_endpoint.dart"
  ],
  "[dart]": {
    "editor.rulers": [120],
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off",
    "editor.selectionHighlight": false,
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.formatOnPaste": true,
    "editor.foldingImportsByDefault": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    "editor.quickSuggestions": {
      "comments": "on",
      "strings": "on",
      "other": "on"
    },
    "editor.links": true
  },
  "search.exclude": {
    "**/.fvm": true,
    ".fvm": true,
    "**/.dart_tool": true,
    ".dart_tool": true,
    "coverage": true,
    "build": true
  },
  "files.watcherExclude": {
    "**/.fvm": true,
    ".fvm": true,
    "**/.dart_tool": true,
    ".dart_tool": true,
    "coverage": true,
    "build": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "debug.openDebug": "openOnDebugBreak",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "agents.md": "claude.md",
    "pubspec.yaml": ".flutter-plugins, .packages, .dart_tool, .flutter-plugins-dependencies, .metadata, .packages, pubspec.lock, build.yaml, analysis_options.yaml, all_lint_rules.yaml, dart*.yaml, flutter*.yaml, icons_launcher.yaml, l10n.yaml, l10n.*.yaml, l10n_*.yaml, melos.yaml, pubspec_overrides.yaml, devtools_options.yaml, repomap.yaml, mise.toml, .fvmrc",
    ".gitignore": ".gitattributes, .gitmodules, .gitmessage, .mailmap, .git-blame*",
    "changelog.md": "history.md, history*, changelog*, changelog.*., changelog_*",
    "readme*": "authors, architecture.md, backers.md, citation*, code_of_conduct.md, codeowners, conventions.md, contributing.md, contributors, copying, credits, deployment.md, integrations.md, localization.md, governance.md, history.md, license*, maintainers, readme*, security.md, sponsors.md, howto.md",
    "*.dart": "i_$(capture).dart, $(capture).g.dart, $(capture).gr.dart, $(capture).freezed.dart, $(capture).config.dart, $(capture).chopper.dart, $(capture).drift, $(capture)_io.dart, $(capture)_web.dart, $(capture)_shared.dart, $(capture)_stub.dart, $(capture).mocks.dart, $(capture)_skeleton.dart ",
    "*.graphql": "$(capture).gql.dart, $(capture).*.gql.dart",
    "firebase.json": " .firebaserc",
    "main.dart": "runner_io.dart, runner_shared.dart, runner_stub.dart, runner_web.dart, runner_vm.dart, runner_js.dart, runner_wasm.dart, runner_mobile.dart, runner_desktop.dart"
  },
  "files.associations": {
    "*.drift": "sql"
  },
  "highlight.regexes": {
    "(\"@[^\"\\n]+\":\\s*\\{\\},?)": {
      "filterFileRegex": ".*\\.arb",
      "decorations": [
        {
          "overviewRulerColor": "#d19a66",
          "backgroundColor": "#d19a6633",
          "color": "#282c34",
          "fontWeight": "bold"
        }
      ]
    }
  }
}
