  "version": "0.2.0",
  "configurations": [
    {
      "name": "debug:dev",
      "cwd": "${workspaceFolder}",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "program": "lib/main.dart",
      "args": [
        "--dart-define-from-file=config/development.json",
        "--flavor=dev"
